  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Queue Length (Waiting Vehicles)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "traffic_queue_length",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true,
            "axisBorderShow": false
          },
          "unit": "short"
        }
      }
    },
